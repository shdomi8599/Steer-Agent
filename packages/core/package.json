{
  "name": "@steer-agent/core",
  "version": "0.1.0",
  "description": "Add real-time coaching-style steering to any AI agent loop",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai-agent",
    "steering",
    "human-in-the-loop",
    "real-time",
    "coaching",
    "middleware",
    "langchain",
    "vscode"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
